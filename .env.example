# AI provider keys stay server-side.
# Sprint 2F supports a fallback mode and OpenAI-compatible chat/completions providers.
# Examples:
# AI_PROVIDER=fallback
# AI_PROVIDER=openai
# AI_PROVIDER=openai-compatible
# AI_PROVIDER=local
AI_PROVIDER=fallback
AI_BASE_URL=
AI_MODEL=
AI_API_KEY=
AI_TIMEOUT_MS=20000

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
DOUBAO_API_KEY=

# Speech-to-text stays server-side.
# Examples:
# SPEECH_PROVIDER=fallback
# SPEECH_PROVIDER=openai
# SPEECH_PROVIDER=openai-compatible
# SPEECH_PROVIDER=local
# SPEECH_PROVIDER=local-whisper
# `openai` and `openai-compatible` use /audio/transcriptions.
# `local-whisper` and `whisper-cpp` send multipart audio to SPEECH_ENDPOINT_PATH.
SPEECH_PROVIDER=fallback
SPEECH_BASE_URL=
SPEECH_MODEL=
SPEECH_API_KEY=
SPEECH_TIMEOUT_MS=30000
SPEECH_ENDPOINT_PATH=/inference
SPEECH_FILE_FIELD=file
SPEECH_RESPONSE_TEXT_PATH=text

# Text-to-speech stays server-side, with browser speech as fallback.
# Examples:
# TTS_PROVIDER=fallback
# TTS_PROVIDER=openai
# TTS_PROVIDER=openai-compatible
# TTS_PROVIDER=local
# `openai` and `openai-compatible` use /audio/speech by default.
TTS_PROVIDER=fallback
TTS_BASE_URL=
TTS_MODEL=
TTS_API_KEY=
TTS_VOICE=alloy
TTS_FORMAT=mp3
TTS_TIMEOUT_MS=30000
TTS_ENDPOINT_PATH=/audio/speech
TTS_INSTRUCTIONS=Speak clearly and slowly for a beginner English learner.

# Audio-level pronunciation scoring stays server-side.
# Examples:
# PRONUNCIATION_PROVIDER=fallback
# PRONUNCIATION_PROVIDER=local
# `local` sends multipart audio to PRONUNCIATION_ENDPOINT_PATH.
PRONUNCIATION_PROVIDER=fallback
PRONUNCIATION_BASE_URL=
PRONUNCIATION_MODEL=
PRONUNCIATION_TIMEOUT_MS=30000
PRONUNCIATION_ENDPOINT_PATH=/score-pronunciation
PRONUNCIATION_FILE_FIELD=file
PRONUNCIATION_REFERENCE_TEXT_FIELD=reference_text
PRONUNCIATION_TRANSCRIPT_FIELD=transcript

# Future cloud sync.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Native mobile/desktop release signing secrets.
# These are only required in strict native release CI jobs, not for Web/PWA development.
ANDROID_KEYSTORE_BASE64=
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_PLAY_PACKAGE_NAME=
GOOGLE_PLAY_TRACK=internal
ANDROID_AAB_PATH=

APPLE_TEAM_ID=
APPLE_CERTIFICATE_BASE64=
APPLE_CERTIFICATE_PASSWORD=
APPLE_NOTARIZATION_USERNAME=
APPLE_NOTARIZATION_PASSWORD=
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_API_ISSUER_ID=
APP_STORE_CONNECT_API_KEY_BASE64=
IOS_IPA_PATH=
MACOS_NOTARIZATION_ARTIFACT_PATH=

TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

WINDOWS_CERTIFICATE_BASE64=
WINDOWS_CERTIFICATE_PASSWORD=

CSC_LINK=
CSC_KEY_PASSWORD=

MICROSOFT_STORE_TENANT_ID=
MICROSOFT_STORE_CLIENT_ID=
MICROSOFT_STORE_CLIENT_SECRET=
MICROSOFT_STORE_SELLER_ID=
MICROSOFT_STORE_PRODUCT_ID=
MICROSOFT_STORE_PROJECT_PATH=
WINDOWS_STORE_PACKAGE_PATH=
