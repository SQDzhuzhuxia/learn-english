# AI provider keys stay server-side.
# Sprint 2F supports a fallback mode and OpenAI-compatible chat/completions providers.
# Examples:
# AI_PROVIDER=fallback
# AI_PROVIDER=openai
# AI_PROVIDER=openai-compatible
# AI_PROVIDER=local
AI_PROVIDER=fallback
AI_BASE_URL=
AI_MODEL=
AI_API_KEY=
AI_TIMEOUT_MS=20000

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
DOUBAO_API_KEY=

# Speech-to-text stays server-side.
# Examples:
# SPEECH_PROVIDER=fallback
# SPEECH_PROVIDER=openai
# SPEECH_PROVIDER=openai-compatible
# SPEECH_PROVIDER=local
# SPEECH_PROVIDER=local-whisper
# `openai` and `openai-compatible` use /audio/transcriptions.
# `local-whisper` and `whisper-cpp` send multipart audio to SPEECH_ENDPOINT_PATH.
SPEECH_PROVIDER=fallback
SPEECH_BASE_URL=
SPEECH_MODEL=
SPEECH_API_KEY=
SPEECH_TIMEOUT_MS=30000
SPEECH_ENDPOINT_PATH=/inference
SPEECH_FILE_FIELD=file
SPEECH_RESPONSE_TEXT_PATH=text

# Future cloud sync.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
