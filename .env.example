# AI provider keys stay server-side.
# Sprint 2F supports a fallback mode and OpenAI-compatible chat/completions providers.
# Examples:
# AI_PROVIDER=fallback
# AI_PROVIDER=openai
# AI_PROVIDER=openai-compatible
# AI_PROVIDER=local
AI_PROVIDER=fallback
AI_BASE_URL=
AI_MODEL=
AI_API_KEY=
AI_TIMEOUT_MS=20000

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
DOUBAO_API_KEY=

# Future cloud sync.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
